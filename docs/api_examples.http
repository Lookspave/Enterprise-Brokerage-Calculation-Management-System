### Login
POST http://127.0.0.1:8000/auth/login
Content-Type: application/x-www-form-urlencoded

username=admin&password=admin123

### Current user
GET http://127.0.0.1:8000/auth/me
Authorization: Bearer {{token}}

### Create client
POST http://127.0.0.1:8000/client
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "client_id": "C-100",
  "client_name": "Retail Client",
  "client_type": "RETAIL",
  "country": "IN"
}

### Create product
POST http://127.0.0.1:8000/product
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "product_id": "P-EQ",
  "product_code": "EQUITY",
  "product_name": "Cash Equity",
  "asset_class": "EQUITY"
}

### Create brokerage rule
POST http://127.0.0.1:8000/rules
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "product_code": "EQUITY",
  "client_type": "RETAIL",
  "exchange": "NSE",
  "country": "IN",
  "currency": "INR",
  "trade_side": "ANY",
  "brokerage_type": "PERCENTAGE",
  "brokerage_value": "0.25",
  "effective_date": "2026-01-01",
  "priority": 100
}

### Create trade
POST http://127.0.0.1:8000/trade
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "trade_id": "T-100",
  "client_id": "C-100",
  "product_id": "P-EQ",
  "quantity": "100",
  "price": "250.00",
  "currency": "INR",
  "exchange": "NSE",
  "trade_side": "BUY",
  "trade_date": "2026-07-11"
}

### Calculate brokerage
POST http://127.0.0.1:8000/calculate
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "trade_id": "T-100",
  "calculated_by": "api-user"
}

### Batch calculate validated trades from an import
POST http://127.0.0.1:8000/calculations/batch
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "import_id": 1,
  "calculated_by": "batch-user"
}

### Import trades from CSV
POST http://127.0.0.1:8000/trades/import
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="imported_by"

api-user
--boundary
Content-Disposition: form-data; name="file"; filename="trades.csv"
Content-Type: text/csv

trade_id,client_id,product_id,quantity,price,currency,exchange,trade_side,trade_date
T-101,C-100,P-EQ,100,250.00,INR,NSE,BUY,2026-07-11
--boundary--

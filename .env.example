EBCMS_APP_NAME="Enterprise Brokerage Calculation & Management System"
EBCMS_DATABASE_URL="sqlite:///./ebcms.db"
EBCMS_ALLOWED_CURRENCIES="INR,USD,EUR,GBP"
EBCMS_DEFAULT_GST_RATE="0.18"
EBCMS_DEFAULT_STT_RATE="0.00025"
EBCMS_DEFAULT_EXCHANGE_TXN_RATE="0.0000325"
EBCMS_DEFAULT_SEBI_RATE="0.000001"
EBCMS_LOG_LEVEL="INFO"
EBCMS_AUTH_SECRET_KEY="change-this-local-development-secret"
EBCMS_ACCESS_TOKEN_EXPIRE_MINUTES="60"
EBCMS_BOOTSTRAP_ADMIN_USERNAME="admin"
EBCMS_BOOTSTRAP_ADMIN_PASSWORD="admin123"
EBCMS_BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
